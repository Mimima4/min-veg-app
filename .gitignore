# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
# Do not gitignore src/server/vgs/generated/ — Vercel NFT excludes ignored paths from lambdas.
# contour-b-scheduler.bundle.mjs is created by `npm run build` and must ship with API routes.

# owner-held (charters, SQL bundles, session logs — never commit)
/owner-held/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# supabase CLI link state (transient)
supabase/.temp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
scripts/.vercel-bundle/
